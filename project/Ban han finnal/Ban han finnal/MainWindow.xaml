<Window x:Class="MiniPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MiniPOS - Main"
        Height="760" Width="1360"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="84"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#C62828">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtStaffInfo"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"/>
                    <TextBlock Text="Đăng nhập thành công"
                       Foreground="#FFEAEA"
                       FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                   Text="Phần mềm quản lý cửa hàng mini - Crew 5"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="White"
                   FontSize="25"
                   FontWeight="Bold"/>

                <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <Button Content="Chức năng"
                    Width="110"
                    Height="40"
                    Margin="0,0,10,0"
                    Background="#FFEBEE"
                    Foreground="#B71C1C"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="btnFeature_Click"/>

                    <Button Content="Đăng xuất"
                    Width="120"
                    Height="40"
                    Background="White"
                    Foreground="#B71C1C"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="390"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Background="White"
                    BorderBrush="#F0D0D0"
                    BorderThickness="1"
                    CornerRadius="16">
                <StackPanel Margin="14">
                    <TextBlock Text="Danh mục mua sắm"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#B71C1C"
                               Margin="0,4,0,16"/>

                    <Button Content="Nước ngọt"
                            Tag="Drink"
                            Height="48"
                            Margin="0,0,0,10"
                            Background="#D32F2F"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CategoryButton_Click"/>

                    <Button Content="Bánh ngọt"
                            Tag="Cake"
                            Height="48"
                            Margin="0,0,0,10"
                            Background="#E53935"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CategoryButton_Click"/>

                    <Button Content="Snack"
                            Tag="Snack"
                            Height="48"
                            Margin="0,0,0,10"
                            Background="#F44336"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CategoryButton_Click"/>

                    <Button Content="Mì gói"
                            Tag="Noodle"
                            Height="48"
                            Margin="0,0,0,10"
                            Background="#D84315"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CategoryButton_Click"/>

                    <Button Content="Cà phê"
                            Tag="Coffee"
                            Height="48"
                            Margin="0,0,0,10"
                            Background="#BF360C"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CategoryButton_Click"/>

                    <Separator Margin="0,18,0,12"/>

                    <TextBlock Text="Tìm kiếm sản phẩm"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#444"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="txtSearch"
                             Height="40"
                             Padding="10,8"
                             FontSize="14"
                             TextChanged="txtSearch_TextChanged"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,0,10,0"
                    Background="White"
                    BorderBrush="#F0D0D0"
                    BorderThickness="1"
                    CornerRadius="16">
                <DockPanel Margin="14">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock x:Name="txtCategoryTitle"
                                   Text="Chọn danh mục để hiển thị sản phẩm"
                                   FontSize="23"
                                   FontWeight="Bold"
                                   Foreground="#B71C1C"/>
                        <TextBlock x:Name="txtProductCount"
                                   Margin="0,4,0,12"
                                   FontSize="13"
                                   Foreground="#777"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="ProductPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#F0D0D0"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Giỏ hàng"
                               FontSize="23"
                               FontWeight="Bold"
                               Foreground="#B71C1C"/>

                    <ListView x:Name="lvCart"
                              Grid.Row="1"
                              Margin="0,12,0,12"
                              BorderThickness="0"
                              SelectionMode="Single">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Sản phẩm" Width="150" DisplayMemberBinding="{Binding DisplayName}"/>
                                <GridViewColumn Header="SL" Width="40" DisplayMemberBinding="{Binding Qty}"/>
                                <GridViewColumn Header="Đơn giá" Width="90" DisplayMemberBinding="{Binding PriceText}"/>
                                <GridViewColumn Header="Thành tiền" Width="95" DisplayMemberBinding="{Binding TotalText}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Button Content="−"
                                Width="48"
                                Height="36"
                                Margin="4"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#EF5350"
                                Foreground="White"
                                BorderThickness="0"
                                Click="btnDecrease_Click"/>

                        <Button Content="+"
                                Width="48"
                                Height="36"
                                Margin="4"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#D32F2F"
                                Foreground="White"
                                BorderThickness="0"
                                Click="btnIncrease_Click"/>

                        <Button Content="Xóa món"
                                Width="90"
                                Height="36"
                                Margin="4"
                                Background="#B71C1C"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="btnRemove_Click"/>

                        <Button Content="Xóa tất cả"
                                Width="100"
                                Height="36"
                                Margin="4"
                                Background="#8E0000"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="btnClearCart_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,12">
                        <TextBlock x:Name="txtItemCount"
                                   Text="Số món: 0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#555"/>
                        <TextBlock x:Name="txtTotal"
                                   Text="Tổng tiền: 0 đ"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#D32F2F"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Row="4"
                            Content="Thanh toán"
                            Height="52"
                            Background="#C62828"
                            Foreground="White"
                            FontSize="17"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnPay_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>