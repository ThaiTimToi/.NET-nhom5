<Window x:Class="MiniPOS.RevenueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thống kê doanh thu"
        Height="420" Width="620"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F8">
    <Grid>
        <Border Margin="20" Background="White" CornerRadius="16" BorderBrush="#F0D0D0" BorderThickness="1">
            <StackPanel Margin="20">
                <TextBlock Text="Thống kê doanh thu"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#B71C1C"/>

                <Border Margin="0,25,0,10" Background="#FFEBEE" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Doanh thu hôm nay: 3,250,000 đ" FontSize="20" FontWeight="Bold" Foreground="#C62828"/>
                        <TextBlock Text="Số đơn hôm nay: 52" Margin="0,10,0,0" FontSize="16"/>
                        <TextBlock Text="Đơn trung bình: 62,500 đ" Margin="0,6,0,0" FontSize="16"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,10,0,10" Background="#FFF3E0" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Doanh thu tháng này: 68,900,000 đ" FontSize="20" FontWeight="Bold" Foreground="#E65100"/>
                        <TextBlock Text="Tăng 12% so với tháng trước" Margin="0,10,0,0" FontSize="16"/>
                    </StackPanel>
                </Border>

                <Button Content="Đóng"
                        Height="42"
                        Margin="0,20,0,0"
                        Background="#D32F2F"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>