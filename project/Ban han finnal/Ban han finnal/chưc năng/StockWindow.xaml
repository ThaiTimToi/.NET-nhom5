<Window x:Class="MiniPOS.StockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kiểm tra tồn kho"
        Height="450" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F8">
    <Grid>
        <Border Margin="20" Background="White" CornerRadius="16" BorderBrush="#F0D0D0" BorderThickness="1">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top"
                           Text="Kiểm tra tồn kho"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#B71C1C"
                           Margin="0,0,0,15"/>

                <ListView x:Name="lvStock">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Tên sản phẩm" Width="240" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Loại" Width="150" DisplayMemberBinding="{Binding Category}"/>
                            <GridViewColumn Header="Số lượng còn" Width="120" DisplayMemberBinding="{Binding Quantity}"/>
                            <GridViewColumn Header="Trạng thái" Width="120" DisplayMemberBinding="{Binding Status}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>
    </Grid>
</Window>