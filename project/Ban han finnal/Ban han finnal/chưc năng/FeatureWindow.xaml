<Window x:Class="MiniPOS.FeatureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chức năng hệ thống"
        Height="520" Width="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF8F8">
    <Grid>
        <Border Margin="20"
                Background="White"
                BorderBrush="#F0D0D0"
                BorderThickness="1"
                CornerRadius="18">
            <DockPanel Margin="18">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock Text="Chức năng hệ thống"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#B71C1C"/>
                    <TextBlock Text="Chọn chức năng muốn sử dụng"
                               Margin="0,6,0,0"
                               FontSize="14"
                               Foreground="#777"/>
                </StackPanel>

                <UniformGrid Rows="3" Columns="3">
                    <Button Content="Thêm hàng"
                            Margin="8"
                            Height="95"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#D32F2F"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnAddProduct_Click"/>

                    <Button Content="Lịch sử giao dịch"
                            Margin="8"
                            Height="95"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#E53935"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnHistory_Click"/>

                    <Button Content="Kiểm tra CTKM"
                            Margin="8"
                            Height="95"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#F44336"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnPromotion_Click"/>

                    <Button Content="Quản lý nhân viên"
                            Margin="8"
                            Height="95"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#D84315"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnStaff_Click"/>

                    <Button Content="Kiểm tra tồn kho"
                            Margin="8"
                            Height="95"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnStock_Click"/>

                    <Button Content="Thống kê doanh thu"
                            Margin="8"
                            Height="95"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#B71C1C"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnRevenue_Click"/>

                    <Button Content="Cài đặt máy POS"
                            Margin="8"
                            Height="95"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#880E4F"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnSetting_Click"/>

                    <Button Content="Đóng"
                            Margin="8"
                            Height="95"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#4E342E"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnClose_Click"/>
                </UniformGrid>
            </DockPanel>
        </Border>
    </Grid>
</Window>