<Window x:Class="MiniPOS.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm hàng"
        Height="420" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F8">
    <Grid>
        <Border Margin="20" Background="White" CornerRadius="16" BorderBrush="#F0D0D0" BorderThickness="1">
            <StackPanel Margin="20">
                <TextBlock Text="Thêm hàng"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#B71C1C"/>

                <TextBlock Text="Tên sản phẩm" Margin="0,20,0,5"/>
                <TextBox x:Name="txtName" Height="35"/>

                <TextBlock Text="Loại hàng" Margin="0,12,0,5"/>
                <ComboBox x:Name="cmbCategory" Height="35" SelectedIndex="0">
                    <ComboBoxItem Content="Nước ngọt"/>
                    <ComboBoxItem Content="Bánh ngọt"/>
                    <ComboBoxItem Content="Snack"/>
                    <ComboBoxItem Content="Mì gói"/>
                    <ComboBoxItem Content="Cà phê"/>
                </ComboBox>

                <TextBlock Text="Giá bán" Margin="0,12,0,5"/>
                <TextBox x:Name="txtPrice" Height="35"/>

                <Button Content="Lưu sản phẩm"
                        Height="42"
                        Margin="0,24,0,0"
                        Background="#D32F2F"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>