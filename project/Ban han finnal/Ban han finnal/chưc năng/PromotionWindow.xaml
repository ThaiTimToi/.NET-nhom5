<Window x:Class="MiniPOS.PromotionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kiểm tra CTKM"
        Height="420" Width="620"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F8">
    <Grid>
        <Border Margin="20" Background="White" CornerRadius="16" BorderBrush="#F0D0D0" BorderThickness="1">
            <StackPanel Margin="20">
                <TextBlock Text="Chương trình khuyến mãi"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#B71C1C"/>

                <ListBox Margin="0,20,0,0" Height="260">
                    <ListBoxItem Content="Mua 2 trà sữa giảm 10%"/>
                    <ListBoxItem Content="Hóa đơn từ 100,000 đ tặng 1 snack"/>
                    <ListBoxItem Content="Mì gói mua 5 tặng 1"/>
                    <ListBoxItem Content="Cà phê size L giảm 5,000 đ"/>
                    <ListBoxItem Content="Khách hàng mới giảm 15% đơn đầu tiên"/>
                </ListBox>

                <Button Content="Đóng"
                        Height="40"
                        Margin="0,20,0,0"
                        Background="#D32F2F"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>