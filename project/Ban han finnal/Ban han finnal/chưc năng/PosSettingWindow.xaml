<Window x:Class="MiniPOS.PosSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cài đặt máy POS"
        Height="430" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F8">
    <Grid>
        <Border Margin="20" Background="White" CornerRadius="16" BorderBrush="#F0D0D0" BorderThickness="1">
            <StackPanel Margin="20">
                <TextBlock Text="Cài đặt máy POS"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#B71C1C"/>

                <CheckBox x:Name="chkPrintAuto" Content="Tự động in hóa đơn sau thanh toán" Margin="0,24,0,10" FontSize="15"/>
                <CheckBox x:Name="chkSound" Content="Bật âm thanh thông báo" Margin="0,0,0,10" FontSize="15"/>
                <CheckBox x:Name="chkDarkRed" Content="Sử dụng giao diện đỏ đậm" Margin="0,0,0,10" FontSize="15"/>

                <TextBlock Text="Tên quầy" Margin="0,16,0,5"/>
                <TextBox x:Name="txtCounterName" Height="35" Text="Quầy thu ngân 01"/>

                <Button Content="Lưu cài đặt"
                        Height="42"
                        Margin="0,24,0,0"
                        Background="#D32F2F"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>