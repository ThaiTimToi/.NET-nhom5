<Window x:Class="MiniPOS.TransactionHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lịch sử giao dịch"
        Height="450" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F8">
    <Grid>
        <Border Margin="20" Background="White" CornerRadius="16" BorderBrush="#F0D0D0" BorderThickness="1">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top"
                           Text="Lịch sử giao dịch"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#B71C1C"
                           Margin="0,0,0,15"/>

                <ListView x:Name="lvHistory">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Mã GD" Width="100" DisplayMemberBinding="{Binding Code}"/>
                            <GridViewColumn Header="Ngày" Width="140" DisplayMemberBinding="{Binding Date}"/>
                            <GridViewColumn Header="Nhân viên" Width="160" DisplayMemberBinding="{Binding Staff}"/>
                            <GridViewColumn Header="Tổng tiền" Width="120" DisplayMemberBinding="{Binding Total}"/>
                            <GridViewColumn Header="Thanh toán" Width="120" DisplayMemberBinding="{Binding Method}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>
    </Grid>
</Window>