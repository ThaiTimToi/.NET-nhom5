<Window x:Class="MiniPOS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MiniPOS - Login"
        Height="540" Width="980"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF7F7">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#C62828">
            <Grid>
                <StackPanel VerticalAlignment="Center" Margin="48">
                    <TextBlock Text="MiniPOS"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Phần mềm quản lý cửa hàng mini"
                               Margin="0,14,0,0"
                               FontSize="20"
                               Foreground="White"/>
                    <TextBlock Text="Crew 5"
                               Margin="0,8,0,0"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#FFF0F0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Border Width="410"
                    Height="320"
                    CornerRadius="20"
                    Background="White"
                    BorderBrush="#F2C5C5"
                    BorderThickness="1.5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Margin="36">
                    <TextBlock Text="Login"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#B71C1C"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Mã nhân viên"
                               Margin="0,28,0,8"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#333"/>

                    <TextBox x:Name="txtStaffCode"
                             Height="44"
                             FontSize="16"
                             Padding="12,8"
                             BorderBrush="#D32F2F"
                             BorderThickness="1.6"
                             PreviewTextInput="txtStaffCode_PreviewTextInput"/>

                    <TextBlock
                               Margin="0,8,0,0"
                               Foreground="#888"
                               FontSize="12"/>

                    <Button x:Name="btnLogin"
                            Content="Login"
                            Height="46"
                            Margin="0,28,0,0"
                            Background="#D32F2F"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="16"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnLogin_Click"/>

                    <TextBlock Margin="0,20,0,0"
                               TextWrapping="Wrap"
                               Foreground="#666"
                               FontSize="12"
                               Text="Mã hợp lệ: 2033240309 - Võ Văn Thái | 2033240310 - Thảo | 2033240311 - Trân"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>