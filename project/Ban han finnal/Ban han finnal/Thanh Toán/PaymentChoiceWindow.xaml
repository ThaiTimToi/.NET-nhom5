<Window x:Class="MiniPOS.PaymentChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn phương thức thanh toán"
        Height="300" Width="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF8F8">
    <Grid>
        <Border Margin="10,20,30,20"
                Background="White"
                BorderBrush="#F0D0D0"
                BorderThickness="1"
                CornerRadius="16">
            <StackPanel Margin="26">
                <TextBlock x:Name="txtTotal"
                           FontSize="25"
                           FontWeight="Bold"
                           Foreground="#B71C1C"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Chọn hình thức thanh toán"
                           FontSize="15"
                           Foreground="#555" HorizontalAlignment="Center"/>

                <Button Content="Tiền mặt"
                        Height="46"
                        Margin="0,0,0,12"
                        Background="#D32F2F"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="Cash_Click"/>
                <Button Content="Chuyển khoản"
                        Height="46"
                        Background="#EF5350"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="Transfer_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>