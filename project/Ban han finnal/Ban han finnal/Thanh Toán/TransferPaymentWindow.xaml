<Window x:Class="MiniPOS.TransferPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh toán chuyển khoản"
        Height="470" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF8F8">
    <Grid>
        <Border Margin="20"
                Background="White"
                BorderBrush="#F0D0D0"
                BorderThickness="1"
                CornerRadius="16">
            <StackPanel Margin="25">
                <TextBlock x:Name="txtTotal"
                           FontSize="25"
                           FontWeight="Bold"
                           Foreground="#B71C1C"/>

                <TextBlock Text="Chọn phương thức"
                           Margin="0,22,0,8"
                           FontWeight="SemiBold"
                           FontSize="15"/>

                <ComboBox x:Name="cmbMethod"
                          Height="40"
                          FontSize="15"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Momo"/>
                    <ComboBoxItem Content="ZaloPay"/>
                    <ComboBoxItem Content="ShopeePay"/>
                    <ComboBoxItem Content="Banking"/>
                </ComboBox>

                <TextBlock x:Name="txtStatus"
                           Margin="0,24,0,18"
                           Text="Trạng thái: Chưa tạo mã"
                           FontSize="17"
                           FontWeight="Bold"
                           Foreground="#D32F2F"
                           TextWrapping="Wrap"/>

                <ProgressBar x:Name="progressBar"
                             Height="22"
                             Minimum="0"
                             Maximum="10"
                             Value="0"/>

                <Button x:Name="btnTransfer"
                        Content="Thanh toán"
                        Height="48"
                        Margin="0,24,0,0"
                        Background="#C62828"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="16"
                        BorderThickness="0"
                        Click="Pay_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>